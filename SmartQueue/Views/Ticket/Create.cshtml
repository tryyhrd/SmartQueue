@model SmartQueue.ViewModels.QueueTicketViewModel

@{
    ViewBag.Title = "Талон №" + Model.Ticket.Number;
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <style>
        :root {
            --bg-color: #ffffff;
            --card-bg: #ffffff;
            --text-main: #333333;
            --text-secondary: #666666;
            --accent-red: #ed1c24;
            --accent-grey: #58595b;
            --border-color: #e0e0e0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--bg-color);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .ticket-container {
            background: var(--card-bg);
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
            max-width: 450px;
            width: 100%;
            overflow: hidden;
            border: 1px solid var(--border-color);
            border-top: 4px solid var(--accent-red);
        }

        .ticket-header {
            background: var(--card-bg);
            color: var(--text-main);
            padding: 25px;
            text-align: center;
            border-bottom: 2px solid rgba(0,0,0,0.05);
        }

            .ticket-header h1 {
                font-size: 28px;
                margin-bottom: 5px;
                color: var(--accent-red);
                font-weight: 800;
                text-transform: uppercase;
            }

            .ticket-header p {
                font-size: 14px;
                color: var(--text-secondary);
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .ticket-body {
            padding: 30px;
        }

        .ticket-number {
            text-align: center;
            margin-bottom: 30px;
            padding: 20px;
            background: #f8f9fa;
        }

            .ticket-number .label {
                font-size: 14px;
                color: var(--accent-red);
                margin-bottom: 5px;
                text-transform: uppercase;
                letter-spacing: 2px;
                font-weight: 700;
            }

            .ticket-number .value {
                font-size: 48px;
                font-weight: 900;
                color: var(--text-main);
            }

        .ticket-info {
            margin-bottom: 20px;
        }

        .ticket-info-row {
            display: flex;
            justify-content: space-between;
            padding: 15px 0;
            border-bottom: 1px solid #eee;
        }

            .ticket-info-row:last-child {
                border-bottom: none;
            }

            .ticket-info-row .label {
                font-size: 14px;
                color: var(--text-secondary);
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .ticket-info-row .value {
                font-size: 16px;
                color: var(--text-main);
                font-weight: 700;
                text-align: right;
            }

        .ticket-status {
            text-align: center;
            padding: 15px;
            margin-top: 20px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-left: 5px solid transparent;
        }

        .status-waiting {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeaa7;
            border-left-color: #ffc107;
        }

        .status-active {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
            border-left-color: #28a745;
        }

        .status-completed {
            background: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
            border-left-color: #17a2b8;
        }

        .ticket-footer {
            text-align: center;
            padding: 20px;
            background: #f8f9fa;
            font-size: 12px;
            color: var(--text-secondary);
            border-top: 2px solid rgba(0,0,0,0.05);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    </style>
</head>
<body>
    <div class="ticket-container">
        <div class="ticket-header">
            <h1>Электронная очередь</h1>
            <p>Талон на обслуживание</p>
        </div>

        <div class="ticket-body">
            <div class="ticket-number">
                <div class="label">Ваш номер</div>
                <div class="value">@Model.Ticket.Number</div>
            </div>

            <div class="ticket-info">
                <div class="ticket-info-row">
                    <span class="label">Услуга:</span>
                    <span class="value">@Model.Service?.Name</span>
                </div>
                <div class="ticket-info-row">
                    <span class="label">Дата выдачи:</span>
                    <span class="value">@Model.Ticket.CreatedAt.ToString("dd.MM.yyyy")</span>
                </div>
                <div class="ticket-info-row">
                    <span class="label">Время выдачи:</span>
                    <span class="value">@Model.Ticket.CreatedAt.ToString("HH:mm")</span>
                </div>
            </div>

            <div class="ticket-status @GetStatusClass(Model.Ticket.Status)">
                @GetStatusText(Model.Ticket.Status)
            </div>
        </div>

        <div class="ticket-footer">
            <p>Спасибо за обращение! Пожалуйста, ожидайте вызова.</p>
        </div>
    </div>

    @functions {
        string GetStatusClass(SmartQueue.Data.Models.Ticket.StatusType status)
        {
            return status switch
            {
                SmartQueue.Data.Models.Ticket.StatusType.Waiting => "status-waiting",
                SmartQueue.Data.Models.Ticket.StatusType.Active => "status-active",
                SmartQueue.Data.Models.Ticket.StatusType.Completed => "status-completed",
                _ => "status-waiting"
            };
        }

        string GetStatusText(SmartQueue.Data.Models.Ticket.StatusType status)
        {
            return status switch
            {
                SmartQueue.Data.Models.Ticket.StatusType.Waiting => "Ожидание",
                SmartQueue.Data.Models.Ticket.StatusType.Active => "Принят",
                SmartQueue.Data.Models.Ticket.StatusType.Completed => "Завершён",
                _ => "Ожидание"
            };
        }
    }

    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>

    <script>
        if (typeof signalR !== 'undefined') {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/queueHub")
                .withAutomaticReconnect()
                .build();

            connection.on("OnTicketUpdated", function(update) {
                if (update.id === @Model.Ticket.Id) {
                    location.reload();
                }
            });

            connection.start().catch(err => console.error('SignalR error:', err));
        }
    </script>
</body>
</html>